# --- Application ---
APP_ENV=development
DEBUG=false

# --- Production deployment (Phase 7) ---
# Comma-separated exact origins allowed to call this API from a browser.
# Local dev default shown; in production set this to your real Vercel
# domain(s), e.g. https://app.canopyai.com,https://canopyai.vercel.app
FRONTEND_URL=http://localhost:3000,http://127.0.0.1:3000
# Comma-separated Host headers this API accepts. "*" (shown) is correct
# for local dev and for platforms that already validate Host at their
# edge (Railway/Render/Fly.io). See app/core/config.py for when to narrow this.
ALLOWED_HOSTS=*
# Number of Uvicorn worker processes. Leave at 1 — see the Dockerfile's
# WORKER COUNT comment for why this isn't safe to raise yet.
WEB_CONCURRENCY=1

# --- AI Providers ---
# Groq — used for document classification (model: openai/gpt-oss-20b)
GROQ_API_KEY=your_groq_api_key_here

# Gemini — used for vision extraction (model: gemini-3.5-flash)
GEMINI_API_KEY=your_gemini_api_key_here

# --- Compliance Engine: Global Forest Watch Data API ---
# Required for satellite/geospatial verification. Get a key at
# https://www.globalforestwatch.org/ (account -> API keys) — the Data API
# lives at https://data-api.globalforestwatch.org.
GFW_API_KEY=your_gfw_api_key_here

# --- Real TRACES NT submission (optional — leave unset until you have real
# EU credentials) ---
# There is no shortcut to real values here: this requires actually
# registering with the European Commission — an EU Login account, then
# registering your company as an "Operator" in TRACES NT, then activating
# "Web Services Access" in your profile to get a real Authentication Key.
# See app/core/config.py's TRACES_* field docstrings for the full,
# step-by-step process. Every real CanoryAI deployment today has these
# unset, and that's expected — submission correctly refuses with a clear
# error rather than a confusing auth failure until they're configured.
# TRACES_USERNAME=your_eu_login_username
# TRACES_AUTHENTICATION_KEY=your_real_authentication_key
# TRACES_WEB_SERVICE_CLIENT_ID=eudr-test
# TRACES_BASE_URL=https://acceptance.eudr.webcloud.ec.europa.eu/tracesnt

# --- Audit Vault: PostgreSQL (required) ---
# Async SQLAlchemy connection string — note the `+asyncpg` driver.
# The app's runtime role (here `canopyai_app`) must have been granted only
# SELECT/INSERT on audit_log — see migrations/versions/..._create_audit_log_table.py
# for the exact GRANT/REVOKE statements and why.
DATABASE_URL=postgresql+asyncpg://canopyai_app:your_password@localhost:5432/canopyai
# DATABASE_POOL_SIZE=10
# DATABASE_MAX_OVERFLOW=5
# DATABASE_ECHO=false

# --- Multi-tenancy: Supabase Auth ---
# Project Settings -> API in your Supabase dashboard.
SUPABASE_URL=https://your-project-ref.supabase.co
# Project Settings -> API -> JWT Settings -> JWT Secret
SUPABASE_JWT_SECRET=your_supabase_jwt_secret_here
# SUPABASE_JWT_AUDIENCE=authenticated

# --- Compliance Engine tuning (all optional, sensible defaults apply) ---
# GFW_REQUEST_TIMEOUT_SECONDS=20
# GFW_MAX_RETRIES=3
# MAX_CONCURRENT_SATELLITE_CALLS=8
# EUDR_CUTOFF_YEAR=2020
# MASS_BALANCE_TOLERANCE_FRACTION=0.02

# --- Upload / processing constraints (all optional, sensible defaults apply) ---
# MAX_ZIP_SIZE_BYTES=209715200
# MAX_FILES_PER_ZIP=500
# MAX_SINGLE_FILE_SIZE_BYTES=26214400
# MAX_CONCURRENT_AI_CALLS=5

# --- Logging ---
LOG_LEVEL=INFO
