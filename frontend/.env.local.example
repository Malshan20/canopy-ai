# Base URL of the CanoryAI FastAPI backend (no trailing slash).
NEXT_PUBLIC_API_URL=http://localhost:8000

# Supabase project (Project Settings -> API in your Supabase dashboard).
# The anon key is safe to expose client-side — it has no privileges beyond
# what your RLS policies allow for an authenticated/anonymous session.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# CanoryAI is invite-only (no self-serve signup) — every "create a
# workspace" entry point in the app (signup page, onboarding, workspace
# switcher) is a mailto: link to this address instead of a form.
NEXT_PUBLIC_SALES_EMAIL=sales@yourdomain.com
